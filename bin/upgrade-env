#!/bin/bash
# Upgrade all installed package managers and their tools

set -e

header() {
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  $1"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}

run() {
  local label="$1"
  shift
  echo "=== $label ==="
  "$@" || echo "⚠️  $label failed, continuing..."
  echo ""
}

header "Upgrading Environment"

if command -v brew &>/dev/null; then
  run "Homebrew" brew upgrade
fi

if command -v mise &>/dev/null; then
  run "mise upgrade" mise upgrade
  run "mise reshim" mise reshim
fi

if command -v cargo &>/dev/null && command -v cargo-install-update &>/dev/null; then
  run "Cargo" cargo install-update --locked --all
fi

header "Done"
