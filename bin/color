#!/usr/bin/env python3

#
# ANSI Color code (16colors + 256colors)
#
#  http://ascii-table.com/ansi-escape-sequences.php
#  http://archive.linux.or.jp/JF/JFdocs/Bash-Prompt-HOWTO-5.html

# Escape sequence
#   \033[<code>m or \e[<code>m
#
#   color : \[\033[ <code>m\] \]
#
#   e.g.
#    bg=Blue, Bold, fg=Red
#     1. \033[44;1;31m
#     2. \033[44m\033[1;31m

# Text attributes
#  0  All attributes off
#  1  Bold on
#  4  Underscore (on monochrome display adapter only)
#  5  Blink on
#  7  Reverse video on
#  8  Concealed on

# Foreground colors
#  0;30   Black          1;30   Dark Gray
#  0;34   Blue           1;34   Light Blue
#  0;32   Green          1;32   Light Green
#  0;36   Cyan           1;36   Light Cyan
#  0;31   Red            1;31   Light Red
#  0;35   Purple         1;35   Light Purple
#  0;33   Brown          1;33   Yellow
#  0;37   Light Gray     1;37   White

# Background colors
#  40   Black
#  41   Red
#  42   Green
#  43   Yellow
#  44   Blue
#  45   Magenta
#  46   Cyan
#  47   White

RESET = "\033[0m"

# 16 colors
colors = [
    ("1;37", "White       "),
    ("37", "Light Gray  "),
    ("1;30", "Gray        "),
    ("30", "Black       "),
    ("31", "Red         "),
    ("1;31", "Light Red   "),
    ("32", "Green       "),
    ("1;32", "Light Green "),
    ("33", "Brown       "),
    ("1;33", "Yellow      "),
    ("34", "Blue        "),
    ("1;34", "Light Blue  "),
    ("35", "Purple      "),
    ("1;35", "Pink        "),
    ("36", "Cyan        "),
    ("1;36", "Light Cyan  "),
]

print("=== 16 Colors ===")
print(" On White(47)     On Black(40)     On Default     Color Code")

for code, name in colors:
    on_white = f"\033[47m\033[{code}m  {name}{RESET}"
    on_black = f"\033[40m\033[{code}m  {name}{RESET}"
    on_default = f"\033[{code}m  {name}{RESET}"
    print(f"{on_white}  {on_black}  {on_default}  {code}")

# 256 colors
print()
print("=== 256 Colors ===")

for code in range(256):
    print(f"\033[48;5;{code}m\033[38;5;0m {code:03d} \033[0m", end="")
    if (code + 1) % 16 == 0:
        print(RESET)
print(RESET, end="")
