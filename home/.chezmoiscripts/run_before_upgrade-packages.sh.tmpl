#!/bin/bash
# Upgrade Homebrew and mise packages before applying dotfiles changes

set -e

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📦 Upgrading Packages"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Upgrade Homebrew packages if brew is installed
if command -v brew &>/dev/null; then
  echo "=== Homebrew ==="
  brew upgrade || echo "⚠️  Homebrew upgrade failed, continuing anyway..."
  echo ""
fi

# Upgrade mise tools if mise is installed
if command -v mise &>/dev/null; then
  echo "=== Mise ==="
  mise upgrade || echo "⚠️  Mise upgrade failed, continuing anyway..."
  mise reshim || echo "⚠️  Mise reshim failed, continuing anyway..."
  echo ""
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✓ Upgrade completed"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
