#!/bin/bash
# Rebuild bat's theme cache so custom themes (e.g. ayu-dark, used by git-delta's
# dark variant) are registered with both bat and delta. Without this, delta cannot
# resolve `syntax-theme = ayu-dark` and falls back to a default theme.
#
# This is a run_onchange script: chezmoi re-runs it only when the rendered content
# below changes. Embedding the theme file's hash makes it re-run whenever the
# bundled bat theme is edited.
#
# bat theme hash (forces re-run on change):
# {{ include "dot_config/bat/themes/ayu-dark.tmTheme" | sha256sum }}
if command -v bat &>/dev/null; then
  bat cache --build >/dev/null 2>&1
fi
