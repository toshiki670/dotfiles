#!/bin/bash
# modify_ script: ~/.claude/settings.json のローカル編集（model / effortLevel など）を
# 温存しつつ、dotfiles 由来の共有設定（hooks/statusLine/language/voiceEnabled）を
# 強制上書きする。chezmoi が既存ファイル内容を stdin で渡し、stdout を新しい内容として書き込む。
set -euo pipefail

# 既存の ~/.claude/settings.json（初回 apply 時など未存在なら空 → {} を既定にする）
local_json="$(cat)"
[ -z "$local_json" ] && local_json='{}'

# dotfiles が管理する共有設定。
# - file は .tmpl なので chezmoi が apply 前に template 展開し、rtk の有無で PreToolUse 分岐を評価する。
# - heredoc 区切りを 'JSON' とクォートして bash 展開を無効化し、フック内の $(...) や \" を JSON のまま保持する。
forced_json="$(cat <<'JSON'
{
  "voiceEnabled": true,
  "language": "日本語",
  "theme": "auto",
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline-command.py"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); if [ -n \"$file\" ] && git -C \"$(dirname \"$file\")\" rev-parse --git-dir > /dev/null 2>&1; then echo '{\"decision\": \"allow\", \"reason\": \"File is in a git repository\"}'; fi"
          }
        ]
      }
    ]{{ if lookPath "rtk" }},
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]{{ end }}
  }
}
JSON
)"

# 右辺（forced）優先の shallow merge:
#   - local 固有キー（model / effortLevel 等）は維持
#   - 共有キー（voiceEnabled/language/statusLine/hooks）は dotfiles が常に勝つ
#   - hooks は object ごと差し替え（deep merge ではなく + を使う）
jq -n --argjson local "$local_json" --argjson forced "$forced_json" '$local + $forced'
