#!/bin/bash
# modify_ script: ~/.claude/settings.json のローカル編集（model / effortLevel など）を
# 温存しつつ、dotfiles 由来の共有設定（hooks/statusLine/language/voiceEnabled）を
# 強制上書きする。chezmoi が既存ファイル内容を stdin で渡し、stdout を新しい内容として書き込む。
#
# 強制設定のうち PreToolUse/Bash には "rm→trash ガード" を含む。rm を deny し trash 利用を促す。
# ただし主役は指示（rules/use-trash-not-rm.md）で、本フックは「指示を忘れた時の保険」。役割が
# 保険なので regex は凍結（これ以上磨かない）= 下記の取りこぼし/過剰ブロックは許容する。
# 検知対象 = コマンド位置の rm（sudo/doas/command/builtin ラッパー[オプション可]・絶対パス・
# 複合コマンド/$() 含む）。git rm や rm 部分一致（charm 等）は非該当。
# 既知の取りこぼし: xargs rm / find -exec rm / \rm、および rm を文字列に含むだけのコマンドも弾く
# （回避 = 本文をファイル渡し）。ユーザー向け解説は README.md の "Claude Code" 節を参照。
set -euo pipefail

# 既存の ~/.claude/settings.json（初回 apply 時など未存在なら空 → {} を既定にする）
local_json="$(cat)"
[ -z "$local_json" ] && local_json='{}'

# dotfiles が管理する共有設定。
# - file は .tmpl なので chezmoi が apply 前に template 展開し、rtk の有無で PreToolUse 分岐を評価する。
# - heredoc 区切りを 'JSON' とクォートして bash 展開を無効化し、フック内の $(...) や \" を JSON のまま保持する。
forced_json="$(cat <<'JSON'
{
  "voiceEnabled": true,
  "language": "日本語",
  "theme": "auto",
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline-command.py"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); if [ -n \"$file\" ] && git -C \"$(dirname \"$file\")\" rev-parse --git-dir > /dev/null 2>&1; then echo '{\"decision\": \"allow\", \"reason\": \"File is in a git repository\"}'; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
{{- if lookPath "rtk" }}
          {
            "type": "command",
            "command": "rtk hook claude"
          },
{{- end }}
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty'); if printf '%s' \"$cmd\" | grep -qE '(^|[;&|()])[[:space:]]*((sudo|doas|command|builtin)[[:space:]]+(-[^[:space:]]+([[:space:]]+[^-[:space:]][^[:space:]]*)?[[:space:]]+)*)*([^[:space:];&|()]*/)?rm([[:space:]]|$)'; then printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Do not use rm. Use trash (moves to the macOS Trash) instead, e.g. `trash <file/dir>`. trash handles directories as-is; no -r/-f needed. Only ask the user before permanently deleting if it is truly required.\"}}'; fi",
            "statusMessage": "rm guard (trash)"
          }
        ]
      }
    ]
  }
}
JSON
)"

# 右辺（forced）優先の shallow merge:
#   - local 固有キー（model / effortLevel 等）は維持
#   - 共有キー（voiceEnabled/language/statusLine/hooks）は dotfiles が常に勝つ
#   - hooks は object ごと差し替え（deep merge ではなく + を使う）
jq -n --argjson local "$local_json" --argjson forced "$forced_json" '$local + $forced'
