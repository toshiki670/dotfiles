# PATH: DOTFILES/bin, ~/.local/bin, ~/.cargo/bin (match common.zsh)
# DOTFILES is generated by chezmoi template for deterministic source root.
set -gx DOTFILES "{{ .chezmoi.config.sourceDir }}"

# Prepend in this order so effective search order is: dotfiles, then ~/.local/bin, then cargo.
fish_add_path --global --prepend --move $HOME/.cargo/bin
fish_add_path --global --prepend --move $HOME/.local/bin
fish_add_path --global --prepend --move "$DOTFILES/bin"
